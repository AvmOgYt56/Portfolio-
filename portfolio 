<!DOCTYPE html><html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Design Portfolio</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }
    header {
      padding: 20px;
      text-align: center;
      background: #111827;
    }
    h1 {
      margin: 0;
      font-size: 2rem;
    }
    .container {
      padding: 20px;
    }
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
    }
    .card {
      background: #1f2937;
      padding: 15px;
      border-radius: 10px;
      text-align: center;
    }
    .card img {
      width: 100%;
      border-radius: 10px;
    }
    .btn {
      display: inline-block;
      margin-top: 10px;
      padding: 10px 15px;
      background: #22c55e;
      color: black;
      text-decoration: none;
      border-radius: 8px;
    }
  </style>
</head>
<body><header>
  <h1>Tanmay Designs</h1>
  <p>High Quality Social Media Ads</p>
</header><div class="container">
  <h2>My Work</h2>
  <div class="grid">
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Design">
      <p>Instagram Ad Design</p>
    </div>
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Design">
      <p>Product Promotion</p>
    </div>
    <div class="card">
      <img src="https://via.placeholder.com/300" alt="Design">
      <p>Brand Post</p>
    </div>
  </div>  <h2>Contact Me</h2>
  <p>DM me on Instagram or WhatsApp for work</p>
  <a class="btn" href="#">Contact Now</a>
</div></body>
</html>